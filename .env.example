# Turso Database (required)
TURSO_DB_URL="libsql://your-database.turso.io"
TURSO_DB_AUTH_TOKEN="your-turso-auth-token"

# Auth (optional — needed for sign-in features)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_SECRET=

# Email (optional — needed for magic link emails)
EMAIL_SERVER_URL=
EMAIL_FROM=noreply@contxt.to
