generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  name      String?
  avatarUrl String?
  plan      String    @default("FREE")
  contexts  Context[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Context {
  id         String   @id @default(cuid())
  title      String
  slug       String   @unique
  summary    String
  content    String
  tags       String   @default("[]")
  creatorIp  String?
  claimToken String?
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([slug])
  @@index([claimToken])
  @@index([userId])
}
